# Template for required Vercel environment variables
# Copy to `.vercel.env` locally (do NOT commit) and fill real values
PORT=5000
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<HOST>/<DB_NAME>?sslmode=require&channel_binding=require
FRONTEND_URL=https://org-nu-eight.vercel.app
JWT_ACCESS_EXPIRES_IN=15m
JWT_ACCESS_SECRET=<REPLACE_WITH_STRONG_SECRET>
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_SECRET=<REPLACE_WITH_STRONG_SECRET>
